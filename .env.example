# Required from Phase 1
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Environment — set explicitly in Vercel per environment (production/preview/development)
# Used by logger (BetterStack env tag) and Sentry. Set in .env.local for local dev.
ENVIRONMENT=development
NEXT_PUBLIC_ENVIRONMENT=development

# Phase 2 — observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=   # BetterStack → Sources → your source → Source token
BETTERSTACK_INGEST_URL=    # BetterStack → Sources → your source → Ingest endpoint URL (e.g. https://sXXXXXXX.eu-fsn-3.betterstackdata.com)

# Phase 2a/3 — debug endpoints (enables /api/debug/* routes; never set in Vercel production)
DEBUG_ALLOWED=

# Phase 5 — auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=    # Clerk dashboard → Webhooks → add endpoint → signing secret, this is not needed for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# Phase 4 — database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 6 — payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Phase 7 — domain + email
RESEND_API_KEY=          # Resend dashboard → API Keys → Create
NEXT_PUBLIC_APP_URL=     # https://visascout.io
SUPPORT_EMAIL=           # required — contact form recipient (e.g. support@visascout.io). No fallback.

# Phase 10 — admin dashboard
ADMIN_USER_ID=           # Clerk User ID (e.g. user_2abc...) — gates /admin access. Find in Clerk dashboard → Users → your account.
NEXT_PUBLIC_ADMIN_USER_ID=  # Same value — exposed to client only to show the Admin Dashboard menu link. Safe to expose (ID alone grants nothing).
MONITOR_SECRET=          # Random secret for BetterStack uptime monitor. Set in Vercel env vars. Generate: openssl rand -hex 32



# Rate limiting — Upstash Redis (optional; if not set, rate limiting is skipped in local dev)
# Upstash console → Create Database → REST API → copy URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Brief caps — daily limits per user type (resets midnight UTC)
MAX_BRIEFS_USER=1        # free tier daily cap; bump for promotions (e.g. 2)
MAX_BRIEFS_ADMIN=50      # admin daily cap; fail-safe against compromised account

# PDF generation — local dev only
# Set to path of local Chrome/Chromium (Vercel uses @sparticuz/chromium automatically)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# Invite code system — gate free brief access via single-use codes
# NEXT_PUBLIC_ENABLE_INVITE_CODES: shows/hides the invite code field in the UI (baked at build time)
# INVITE_CODES: comma-separated UUIDs; generate with: node -e "console.log(require('crypto').randomUUID())"
# One code per invited user. Code is permanently consumed on redemption (single-use via DB).
# To revoke: use Admin Dashboard → Early Access Users → Revoke.
NEXT_PUBLIC_ENABLE_INVITE_CODES=
INVITE_CODES=

# Optional
DRY_RUN=true
