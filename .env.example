# Required from Phase 1
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Phase 2 — observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=

# Phase 2a/3 — debug endpoints (enables /api/debug/* routes; never set in Vercel production)
DEBUG_ALLOWED=

# Phase 5 — auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=    # Clerk dashboard → Webhooks → add endpoint → signing secret, this is not needed for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# Phase 4 — database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 6 — payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Phase 7 — domain + email
RESEND_API_KEY=          # Resend dashboard → API Keys → Create
NEXT_PUBLIC_APP_URL=     # https://visascout.io

# Phase 10 — admin dashboard
ADMIN_USER_ID=           # Clerk User ID (e.g. user_2abc...) — gates /admin access. Find in Clerk dashboard → Users → your account.
NEXT_PUBLIC_ADMIN_USER_ID=  # Same value — exposed to client only to show the Admin Dashboard menu link. Safe to expose (ID alone grants nothing).

# Brief caps — daily limits per user type (resets midnight UTC)
MAX_BRIEFS_USER=1        # free tier daily cap; bump for promotions (e.g. 2)
MAX_BRIEFS_ADMIN=50      # admin daily cap; fail-safe against compromised account

# PDF generation — local dev only
# Set to path of local Chrome/Chromium (Vercel uses @sparticuz/chromium automatically)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# Optional
DRY_RUN=true
